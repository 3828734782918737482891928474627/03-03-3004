        -- Luminous special handling (age 6 with neon properties)
        if age == 6 then
            for ageName, isSelected in pairs(ageToggles) do
                if isSelected and ageName == "Luminous" then
                    isNeon = true
                    break
                end
            end
        end
        
        return {
            mega_neon = isMegaNeon,
            neon = isNeon and not isMegaNeon, -- Don't set neon if it's mega neon
            rideable = isFR,
            flyable = isFR,
            age = age
