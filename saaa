local function loadModules()
    local success, result = pcall(function()
        Fsys = require(ReplicatedStorage:WaitForChild("Fsys", 10))
        LoadModule = Fsys.load
        
        ClientData = LoadModule("ClientData")
        RouterClient = LoadModule("RouterClient")
        UIManager = LoadModule("UIManager")
        InventoryDB = LoadModule("InventoryDB")
        KindDB = LoadModule("KindDB")
        DownloadClient = LoadModule("DownloadClient")
        AnimationManager = LoadModule("AnimationManager")
