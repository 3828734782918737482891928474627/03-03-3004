        AilmentsClient = LoadModule("new:AilmentsClient")
        AilmentsDB = LoadModule("new:AilmentsDB")
        CharWrapperClient = LoadModule("CharWrapperClient")
    end)
    
    if not success then
        warn("Failed to load modules: " .. tostring(result))
        return false
    end
    return true
end

